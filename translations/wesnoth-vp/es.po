#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:9
msgid "I... I... failed."
msgstr "Yo... yo... he fallado."

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:10
msgid "Nobody could guide us better than you, Zanza!"
msgstr "¡Nadie podría guiarnos mejor que tú, Zanza!"

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:11
msgid "Then... we are lost."
msgstr "Entonces... estamos perdidos."

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:26
msgid "I did not... forsee this. Thats not ..."
msgstr "Yo no... previ esto. Eso no es..."

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:27
msgid ""
"No! Anexir! Our tribe needs your guidance, we need a spirital leader! We are "
"lost!"
msgstr ""
"¡No! ¡Anexir! ¡Nuestra tribu necesita tu guía, necesitamos un líder "
"espiritual! ¡Estamos perdidos!"

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:44
msgid "Back to my roots."
msgstr "De vuelta a mis raíces."

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:67
#: Vendraxis_Prophecy/macros/deaths.cfg:85
msgid "Not... now..."
msgstr "No... ahora..."

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:68
#: Vendraxis_Prophecy/macros/deaths.cfg:86
msgid "Tarex no!"
msgstr "¡Tarex, no!"

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:100
msgid "Burn in the depth you came from fiend!"
msgstr "¡Arde en las profundidades de donde viniste, demonio!"

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:101
msgid "Salanix no, we just met!"
msgstr "¡Salanix, no, acabamos de conocernos!"

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:119
msgid "I can see... sand dunes... and golden wings..."
msgstr "Puedo ver... dunas de arena... y alas doradas..."

#. [event]
#: Vendraxis_Prophecy/macros/deaths.cfg:120
msgid "Arnatrax... the One will lead you home."
msgstr "Arnatrax... el Único te guiará a casa."

