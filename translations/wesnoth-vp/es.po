#: Vendraxis_Prophecy/achievements.cfg:22
msgid ""
"Scenario ??: Crocodiles? Nobody told me that the lizards have crocodiles!"
msgstr ""
"Escenario ??: ¿Cocodrilos? ¡Nadie me dijo que los lagartos tienen cocodrilos!"

#. [achievement], id=crocodile
